+function normalizeSaveUserParlayInput(input: {
+  userId: string;
+  body: SaveMeParlayInput;
+}): {
+  title: string;
+  explanation: string;
+  mode: "REAL" | "PRACTICE";
+  wagerAmount: number;
+  aiGenerated: boolean;
+  source: string;
+  clientRef: string | null;
+  combinedOdds: number | null;
+  selectionSummary: string;
+  parentEventId: string;
