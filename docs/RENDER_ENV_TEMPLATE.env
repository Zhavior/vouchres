# Render environment paste template
#
# Copy these into Render → vouchedge-api → Environment.
# Do NOT commit real secrets. Generate CRON_SECRET with: openssl rand -hex 32
#
# After saving, redeploy and run:
#   BASE_URL=https://<your-service>.onrender.com npm run production-smoke

# --- required (boot fail-closed) ---
NODE_ENV=production
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN
CRON_SECRET=YOUR_LONG_RANDOM_SECRET
SENTRY_DSN=https://YOUR_KEY@o0.ingest.sentry.io/0
TRUST_PROXY=1

# --- required for browser clients ---
FRONTEND_URL=https://vouchedge.app
CORS_ALLOWED_ORIGINS=https://vouchedge.app,https://www.vouchedge.app
MLB_API_BASE_URL=https://statsapi.mlb.com/api

# --- optional product ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
BLOCKED_JURISDICTIONS=

# --- optional billing (STRIPE_WEBHOOK_SECRET required if STRIPE_SECRET_KEY set) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_YEARLY_PRICE_ID=
STRIPE_CREATOR_MONTHLY_PRICE_ID=
STRIPE_CREATOR_YEARLY_PRICE_ID=

# --- vouchedge-grader cron service (subset) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# MLB_API_BASE_URL=https://statsapi.mlb.com/api

# --- vouchedge-deleter cron service (subset) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
