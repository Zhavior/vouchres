{
  "name": "vouchedge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --max-old-space-size=8192 --env-file=.env.local --import tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild server/cron/dailyGradeJob.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/gradeJob.cjs && esbuild server/cron/dailyDeleteJob.ts --bundle --platform=node --format=cjs --packages=external --external:stripe --external:../middleware/auth --outfile=dist/deleteJob.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "eslint . || true",
    "verify:daily-report-cache": "tsx scripts/verifyDailyReportCache.ts",
    "verify:grading-flow": "tsx scripts/verifyGradingFlow.ts",
    "verify:composer-options": "tsx scripts/verifyComposerOptions.ts",
    "verify:notifications": "tsx scripts/verifyNotifications.ts",
    "verify:ai-parlays": "tsx scripts/verifyAiParlays.ts",
    "verify:entitlements": "tsx scripts/verifyEntitlements.ts",
    "verify:auth-smoke": "tsx scripts/verifyAuthSmoke.ts",
    "verify:billing-hardening": "tsx scripts/verifyBillingHardening.ts",
    "verify:vercel-api-parity": "tsx scripts/verifyVercelApiParity.ts",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint && npm run build",
    "lint:strict": "eslint . --max-warnings=0",
    "quality:strict": "npm run typecheck && npm run lint:strict && npm run build",
    "knip": "knip",
    "knip:production": "knip --production",
    "analyze": "vite build --mode analyze"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^2.10.0",
    "@sentry/node": "^10.61.0",
    "@sentry/react": "^10.61.0",
    "@supabase/supabase-js": "^2.108.2",
    "@upstash/redis": "^1.38.0",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.42.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.5.0",
    "posthog-js": "^1.393.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "stripe": "^22.3.0",
    "vite": "^6.2.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.21",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "knip": "^6.24.0",
    "react-refresh": "^0.18.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.2.3"
  }
}
