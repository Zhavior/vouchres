{
  "name": "vouchedge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "PORT=3000 node --max-old-space-size=12000 --import tsx server.ts",
    "dev:stop": "sh -c 'PORT=${PORT:-3000}; PIDS=$(lsof -ti :$PORT 2>/dev/null); if [ -n \"$PIDS\" ]; then echo \"[dev:stop] Killing PID(s) on port $PORT: $PIDS\"; echo \"$PIDS\" | xargs kill -9 2>/dev/null || true; sleep 1; else echo \"[dev:stop] Port $PORT is free\"; fi'",
    "dev:port": "sh -c 'PORT=${PORT:-3000}; lsof -nP -iTCP:$PORT -sTCP:LISTEN || echo \"Port $PORT is free\"'",
    "dev:restart": "npm run dev:stop && npm run dev",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && esbuild server/cron/dailyGradeJob.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/gradeJob.cjs && esbuild server/cron/dailyDeleteJob.ts --bundle --platform=node --format=cjs --packages=external --external:stripe --external:../middleware/auth --outfile=dist/deleteJob.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "eslint . || true",
    "verify:daily-report-cache": "tsx scripts/verifyDailyReportCache.ts",
    "verify:grading-flow": "tsx scripts/verifyGradingFlow.ts",
    "verify:composer-options": "tsx scripts/verifyComposerOptions.ts",
    "verify:notifications": "tsx scripts/verifyNotifications.ts",
    "verify:ai-parlays": "tsx scripts/verifyAiParlays.ts",
    "verify:entitlements": "tsx scripts/verifyEntitlements.ts",
    "verify:auth-smoke": "tsx scripts/verifyAuthSmoke.ts",
    "verify:trustos": "tsx scripts/smokeTrustOs.ts",
    "verify:trustos-db": "node --env-file=.env.local scripts/verifyTrustOsMigration.mjs",
    "migrate:trustos": "node --env-file=.env.local scripts/applyTrustOsMigration.mjs",
    "verify:billing-hardening": "tsx scripts/verifyBillingHardening.ts",
    "verify:vercel-api-parity": "tsx scripts/verifyVercelApiParity.ts",
    "sentry:test": "tsx scripts/sentryTestError.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:parlay": "playwright test e2e/parlay-os.smoke.spec.ts",
    "verify:parlayos": "tsx scripts/verifyParlayOs.ts",
    "verify:odds-api": "node --env-file=.env.local --import tsx scripts/verifyOddsApi.ts",
    "verify:parlayos-db": "node --env-file=.env.local scripts/verifyTrustOsMigration.mjs",
    "bundle-budget": "node scripts/bundle-budget.mjs",
    "perf-check": "node scripts/perf-check.mjs",
    "staging-soak": "node scripts/staging-soak.mjs",
    "staging-soak:strict": "node scripts/staging-soak.mjs --strict --local-only",
    "production-smoke": "node scripts/production-smoke.mjs",
    "configure:supabase-auth-urls": "tsx scripts/configureSupabaseAuthUrls.ts",
    "lighthouse-ci": "node scripts/lighthouse-ci.mjs",
    "typecheck": "tsc --noEmit",
    "quality": "npm run typecheck && npm run lint && npm run build",
    "lint:strict": "eslint src server tests --quiet",
    "quality:strict": "npm run typecheck && npm run lint:strict && npm run build",
    "knip": "knip",
    "knip:production": "knip --production",
    "analyze": "vite build --mode analyze",
    "cap:sync": "vite build && npx cap sync",
    "cap:sync:android": "vite build && npx cap sync android",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "screenshots:mobile": "node scripts/mobileScreenshots.mjs",
    "brand:assets": "node scripts/generateBrandAssets.mjs",
    "brand:judge": "npx tsx scripts/judgeBrandMark.ts",
    "screenshots:splash": "node scripts/splashScreenshots.mjs",
    "brand:ve-type": "node scripts/buildVeMarkFromFont.mjs"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@capacitor/android": "^8.4.2",
    "@capacitor/core": "^8.4.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^2.10.0",
    "@sentry/node": "^10.61.0",
    "@sentry/react": "^10.61.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-virtual": "^3.14.5",
    "@types/d3-hierarchy": "^3.1.7",
    "@upstash/redis": "^1.38.0",
    "@vercel/speed-insights": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cytoscape": "^3.34.0",
    "d3-hierarchy": "^3.1.2",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^12.42.0",
    "google-auth-library": "^10.9.0",
    "helmet": "^8.2.0",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.16.0",
    "motion": "^12.23.24",
    "node-cron": "^4.5.0",
    "opentimestamps": "^0.4.9",
    "posthog-js": "^1.393.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "sharp": "^0.35.3",
    "stripe": "^22.3.0",
    "vite": "^6.2.3",
    "vitest": "^4.1.9",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.51.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.21",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "esbuild": "^0.25.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "knip": "^6.24.0",
    "lightningcss": "^1.32.0",
    "opentype.js": "^2.0.0",
    "postgres": "^3.4.7",
    "react-refresh": "^0.18.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.2.3"
  }
}
