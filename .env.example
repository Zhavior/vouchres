# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ---- VouchEdge backend intelligence ----
# MLB Stats API base (free, no key). Override only if proxying.
MLB_API_BASE_URL="https://statsapi.mlb.com/api"

# Optional Gemini model override for the backend AI layer.
# GEMINI_MODEL="gemini-3.5-flash"

# Optional future data providers (not required for the current backbone).
# SPORTSDATA_API_KEY=""
# SPORTRADAR_API_KEY=""
# Optional live odds (ParlayOS — honest TBD when unset).
# ODDS_API_KEY=""
# WEATHER_API_KEY=""

# Frontend: set to your deployed backend origin when the SPA is hosted separately (e.g. Vercel).
# Leave unset for local dev / node-server deploy (same-origin).
VITE_API_BASE_URL=""

# ---- Supabase auth (required for login on localhost:3000) ----
# Copy from Supabase → Project Settings → API
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-server-only"
# Vite exposes only VITE_* to the browser — mirror the values above:
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"
# In Supabase → Authentication → URL Configuration, add:
#   Site URL: http://localhost:3000
#   Redirect URLs: http://localhost:3000/**

# Optional: skip auth gate in dev only (does not replace Supabase for real login)
# VITE_DEV_BYPASS_AUTH="false"

# ---- Observability ----
# Frontend Sentry (browser/React project — exposed to Vite via VITE_ prefix).
VITE_SENTRY_DSN=""
# VITE_SENTRY_ENV="development"

# Server Sentry (Express/API — never VITE_ prefix; use a separate backend project).
# REQUIRED in production — validateProductionEnvAtBoot() fails closed without it.
SENTRY_DSN=""
# Optional Sentry environment label (staging, production). Defaults to NODE_ENV.
SENTRY_ENVIRONMENT=""

# Source map upload during `npm run build` (CI/Vercel only — never commit this token).
# Create at Sentry → Settings → Auth Tokens. Wizard writes .env.sentry-build-plugin locally.
# SENTRY_AUTH_TOKEN=""

# ---- Upstash Redis (REQUIRED in production) ----
# Multi-instance rate limits, HR board cache, and distributed grade locks.
# Boot fails closed in production when either value is missing.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- Cron auth (REQUIRED in production) ----
# HTTP cron routes require Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=""

# ---- Supabase deploy (step 5 — auth URL configuration) ----
# Personal access token: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=""
# Optional when SUPABASE_URL is unset:
# SUPABASE_PROJECT_REF=""
# Production SPA origin for Site URL + redirect allow-list:
# FRONTEND_URL="https://vouchedge.app"
# Optional staging/preview origin:
# SUPABASE_STAGING_URL=""
# Apply: npm run configure:supabase-auth-urls -- --apply
# Verify: npm run configure:supabase-auth-urls -- --verify

# ---- Proxy / rate-limit identity ----
# Number of trusted reverse-proxy hops (Render/Vercel edge). Default 1.
# Rate limiters use Express req.ip (not leftmost X-Forwarded-For).
TRUST_PROXY="1"

# Single production cron host: see docs/PRODUCTION_HOSTING.md
# Default: Render cron services; vercel.json crons stay empty.

# ---- Jurisdiction policy (legal confirm gate) ----
# Comma-separated ISO-like codes to block at POST /api/legal/confirm and on pick writes.
# Empty = no blocklist (removed legacy stub that blocked nearly every US state).
# Example: BLOCKED_JURISDICTIONS="US-CA,US-TX"
BLOCKED_JURISDICTIONS=""

# ---- MLB upstream circuit breaker (optional tuning) ----
# MLB_CIRCUIT_FAILURE_THRESHOLD="5"
# MLB_CIRCUIT_WINDOW_MS="60000"
# MLB_CIRCUIT_COOLDOWN_MS="30000"
