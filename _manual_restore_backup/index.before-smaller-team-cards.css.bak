/* ===== Daily Players page stability patch ===== */

#root [data-page="daily-players"],
#root .daily-players-page,
#root .daily-players-shell,
#root .daily-players-layout {
  width: 100%;
  max-width: 100%;
  min-width: 0;
  overflow-x: hidden;
}

#root [data-page="daily-players"] *,
#root .daily-players-page *,
#root .daily-players-shell *,
#root .daily-players-layout * {
  min-width: 0;
}

#root [data-page="daily-players"] main,
#root .daily-players-page main,
#root .daily-players-shell main,
#root .daily-players-layout main {
  width: 100%;
  max-width: 1320px;
  margin-inline: auto;
  padding-inline: clamp(16px, 2vw, 28px);
}

#root [data-page="daily-players"] [class*="grid"],
#root .daily-players-page [class*="grid"],
#root .daily-players-shell [class*="grid"],
#root .daily-players-layout [class*="grid"] {
  min-width: 0;
}

#root [data-page="daily-players"] table,
#root .daily-players-page table,
#root .daily-players-shell table,
#root .daily-players-layout table {
  width: 100%;
  max-width: 100%;
}

#root [data-page="daily-players"] .overflow-x-auto,
#root .daily-players-page .overflow-x-auto,
#root .daily-players-shell .overflow-x-auto,
#root .daily-players-layout .overflow-x-auto {
  max-width: 100%;
}


/* ===== Manual fix: remove Daily Players left gutter / shell double-offset ===== */

/* The app content after the fixed sidebar should start once, not twice */
.ve-app-shell,
.ve-shell {
  display: flex;
  width: 100%;
  max-width: 100%;
  overflow-x: hidden;
}

/* Main app region must own the available width */
.ve-app-main,
.ve-page-main {
  flex: 1 1 auto;
  min-width: 0;
  width: 100%;
  max-width: 100%;
  margin-left: 0 !important;
}

/* Daily Players specific: cancel accidental centering/gutter caused by inherited wrappers */
#root [data-page="daily-players"],
#root .daily-players-page,
#root .daily-players-shell,
#root .daily-players-layout {
  margin-left: 0 !important;
  padding-left: 0 !important;
  width: 100%;
  max-width: 100%;
  min-width: 0;
}

/* The actual Daily Players content should sit close to the sidebar with normal padding */
#root [data-page="daily-players"] > *,
#root .daily-players-page > *,
#root .daily-players-shell > *,
#root .daily-players-layout > * {
  margin-left: 0 !important;
  min-width: 0;
}

/* Remove old centered page behavior only for Daily Players */
#root [data-page="daily-players"] main,
#root .daily-players-page main,
#root .daily-players-shell main,
#root .daily-players-layout main {
  max-width: none !important;
  margin-left: 0 !important;
  margin-right: 0 !important;
  padding-left: clamp(18px, 2vw, 32px) !important;
  padding-right: clamp(18px, 2vw, 32px) !important;
}

/* If Daily Players is inside a generic app container, stop auto-centering it */
#root .ve-app-main:has(.daily-players-page),
#root .ve-app-main:has(.daily-players-shell),
#root .ve-app-main:has([data-page="daily-players"]),
#root .ve-page-main:has(.daily-players-page),
#root .ve-page-main:has(.daily-players-shell),
#root .ve-page-main:has([data-page="daily-players"]) {
  margin-left: 0 !important;
  padding-left: 0 !important;
  max-width: none !important;
}

/* Keep matchup carousel scroll inside its own box only */
#root [data-page="daily-players"] .overflow-x-auto,
#root .daily-players-page .overflow-x-auto,
#root .daily-players-shell .overflow-x-auto,
#root .daily-players-layout .overflow-x-auto {
  overflow-x: auto;
  overflow-y: hidden;
  max-width: 100%;
}


/* ===== Actual Daily Players wrapper fix ===== */
#root [data-page="daily-players"].daily-players-page {
  width: 100% !important;
  max-width: none !important;
  min-width: 0 !important;
  margin-left: 0 !important;
  margin-right: 0 !important;
  padding-left: clamp(16px, 1.6vw, 28px) !important;
  padding-right: clamp(16px, 1.6vw, 28px) !important;
  overflow-x: hidden;
}

#root [data-page="daily-players"].daily-players-page > * {
  min-width: 0 !important;
  max-width: 100% !important;
}

#root [data-page="daily-players"] .max-w-7xl,
#root [data-page="daily-players"] .max-w-6xl,
#root [data-page="daily-players"] .max-w-screen-xl,
#root [data-page="daily-players"] .container {
  max-width: none !important;
  width: 100% !important;
  margin-left: 0 !important;
  margin-right: 0 !important;
}

#root [data-page="daily-players"] [class*="grid"] {
  min-width: 0 !important;
}

#root [data-page="daily-players"] [class*="overflow-x"] {
  max-width: 100% !important;
}


/* ===== Emergency beta fix: remove duplicated app-shell sidebar gutter ===== */

/* On authenticated app pages, the sidebar already occupies width.
   The main content must not add another fake sidebar offset. */
#root .ve-app-shell > main,
#root .ve-shell > main,
#root .app-shell > main,
#root .app-layout > main,
#root .dashboard-shell > main {
  margin-left: 0 !important;
  padding-left: 0 !important;
  min-width: 0 !important;
  flex: 1 1 0 !important;
  max-width: none !important;
}

/* Common wrappers directly after sidebar */
#root .ve-app-shell > div:not(.ve-sidebar),
#root .ve-shell > div:not(.ve-sidebar),
#root .app-shell > div:not(.ve-sidebar),
#root .app-layout > div:not(.ve-sidebar),
#root .dashboard-shell > div:not(.ve-sidebar) {
  min-width: 0 !important;
}

/* If the route wrapper is using Tailwind sidebar offsets, cancel them only inside app shells */
#root .ve-app-shell [class*="ml-[240"],
#root .ve-app-shell [class*="ml-[250"],
#root .ve-app-shell [class*="ml-[260"],
#root .ve-app-shell [class*="pl-[240"],
#root .ve-app-shell [class*="pl-[250"],
#root .ve-app-shell [class*="pl-[260"],
#root .ve-shell [class*="ml-[240"],
#root .ve-shell [class*="ml-[250"],
#root .ve-shell [class*="ml-[260"],
#root .ve-shell [class*="pl-[240"],
#root .ve-shell [class*="pl-[250"],
#root .ve-shell [class*="pl-[260"] {
  margin-left: 0 !important;
  padding-left: 0 !important;
}

/* Daily Players should use the full remaining space beside sidebar */
#root [data-page="daily-players"] {
  width: 100% !important;
  max-width: none !important;
  margin-left: 0 !important;
  transform: none !important;
}


/* ===== Right rail / Today's Matchup containment fix ===== */
#right-sidebar-column,
#right-rail-column,
.ve-right-rail,
.ve-feed-right-rail,
aside[aria-label*="Today"],
aside[aria-label*="Matchup"] {
  width: clamp(300px, 22vw, 360px) !important;
  max-width: 360px !important;
  min-width: 0 !important;
  flex: 0 1 360px !important;
  overflow-x: hidden !important;
}

#right-sidebar-column *,
#right-rail-column *,
.ve-right-rail *,
.ve-feed-right-rail * {
  min-width: 0 !important;
  max-width: 100%;
}

#right-sidebar-column [class*="w-[4"],
#right-sidebar-column [class*="w-[5"],
#right-rail-column [class*="w-[4"],
#right-rail-column [class*="w-[5"],
.ve-right-rail [class*="w-[4"],
.ve-feed-right-rail [class*="w-[4"] {
  width: 100% !important;
}

@media (max-width: 1279px) {
  #right-sidebar-column,
  #right-rail-column,
  .ve-right-rail,
  .ve-feed-right-rail {
    display: none !important;
  }
}


/* ===== Daily Players beta redesign: smaller cards + Live Teams slider ===== */

#root [data-page="daily-players"].daily-players-page {
  padding-top: 18px !important;
}

/* Top Live Teams slider */
.daily-live-teams-strip {
  width: 100%;
  max-width: 100%;
  margin: 0 0 22px;
  padding: 16px;
  border: 1px solid rgba(255,255,255,0.085);
  border-radius: 24px;
  background: linear-gradient(180deg, rgba(18,18,20,0.92), rgba(7,7,9,0.96));
  box-shadow: 0 24px 70px rgba(0,0,0,0.34);
  overflow: hidden;
}

.daily-live-teams-header {
  display: flex;
  align-items: end;
  justify-content: space-between;
  gap: 16px;
  margin-bottom: 14px;
}

.daily-live-teams-header h2 {
  margin: 0;
  font-size: clamp(20px, 2vw, 28px);
  line-height: 1;
  letter-spacing: -0.04em;
  color: #f5f5f7;
}

.daily-live-teams-header p {
  margin: 0;
  color: rgba(245,245,247,0.58);
  font-size: 13px;
}

.daily-live-eyebrow {
  margin-bottom: 6px !important;
  color: rgba(245,245,247,0.48) !important;
  text-transform: uppercase;
  letter-spacing: 0.16em;
  font-size: 11px !important;
  font-weight: 700;
}

.daily-live-teams-scroller {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(220px, 260px);
  gap: 12px;
  overflow-x: auto;
  overflow-y: hidden;
  overscroll-behavior-x: contain;
  scroll-snap-type: x proximity;
  padding-bottom: 8px;
}

.daily-live-teams-scroller::-webkit-scrollbar {
  height: 8px;
}

.daily-live-teams-scroller::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.14);
  border-radius: 999px;
}

.daily-live-team-card {
  scroll-snap-align: start;
  min-height: 132px;
  padding: 14px;
  border-radius: 18px;
  border: 1px solid rgba(255,255,255,0.08);
  background: linear-gradient(180deg, rgba(255,255,255,0.055), rgba(255,255,255,0.022));
  box-shadow: none;
}

.daily-live-status,
.daily-live-card-footer {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  color: rgba(245,245,247,0.52);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.11em;
}

.daily-live-status strong {
  color: rgba(245,245,247,0.74);
  font-weight: 700;
}

.daily-live-matchup {
  display: grid;
  gap: 5px;
  margin: 16px 0 14px;
  color: #f5f5f7;
  font-weight: 800;
  letter-spacing: -0.03em;
  font-size: 16px;
}

.daily-live-matchup b {
  color: rgba(245,245,247,0.35);
  font-size: 12px;
}

/* Make Daily Players player cards feel less huge */
#root [data-page="daily-players"] article,
#root [data-page="daily-players"] .rounded-3xl,
#root [data-page="daily-players"] .rounded-2xl {
  border-color: rgba(255,255,255,0.08) !important;
}

/* Tighter card internals only on Daily Players */
#root [data-page="daily-players"] article {
  padding: clamp(12px, 1.2vw, 16px) !important;
}

/* Reduce oversized typography inside Daily Players cards */
#root [data-page="daily-players"] article h3,
#root [data-page="daily-players"] article h4 {
  font-size: clamp(14px, 1.2vw, 17px) !important;
  line-height: 1.1 !important;
}

/* Keep rows/grids contained */
#root [data-page="daily-players"] {
  overflow-x: hidden;
}

#root [data-page="daily-players"] [class*="grid"] {
  min-width: 0 !important;
}

@media (max-width: 760px) {
  .daily-live-teams-strip {
    border-radius: 20px;
    padding: 14px;
  }

  .daily-live-teams-header {
    align-items: start;
    flex-direction: column;
  }

  .daily-live-teams-scroller {
    grid-auto-columns: minmax(205px, 82vw);
  }
}


/* ===== Daily Players Live Teams infinite marquee ===== */

.daily-live-teams-strip {
  position: relative;
}

/* soft fade edges so it feels premium */
.daily-live-teams-strip::before,
.daily-live-teams-strip::after {
  content: "";
  position: absolute;
  top: 64px;
  bottom: 14px;
  width: 76px;
  z-index: 3;
  pointer-events: none;
}

.daily-live-teams-strip::before {
  left: 0;
  background: linear-gradient(90deg, rgba(7,7,9,0.98), rgba(7,7,9,0));
}

.daily-live-teams-strip::after {
  right: 0;
  background: linear-gradient(270deg, rgba(7,7,9,0.98), rgba(7,7,9,0));
}

.daily-live-teams-scroller {
  display: block !important;
  overflow: hidden !important;
  max-width: 100%;
  padding-bottom: 0 !important;
}

.daily-live-teams-track {
  display: flex;
  width: max-content;
  gap: 12px;
  will-change: transform;
  animation: ve-live-teams-marquee 42s linear infinite;
}

.daily-live-teams-strip:hover .daily-live-teams-track {
  animation-play-state: paused;
}

.daily-live-team-card {
  flex: 0 0 242px;
}

@keyframes ve-live-teams-marquee {
  from {
    transform: translateX(0);
  }

  to {
    transform: translateX(-50%);
  }
}

/* Respect users who prefer reduced motion */
@media (prefers-reduced-motion: reduce) {
  .daily-live-teams-track {
    animation: none;
    overflow-x: auto;
  }
}

@media (max-width: 760px) {
  .daily-live-teams-track {
    animation-duration: 34s;
  }

  .daily-live-team-card {
    flex-basis: 218px;
  }

  .daily-live-teams-strip::before,
  .daily-live-teams-strip::after {
    width: 38px;
  }
}


/* ===== Daily Players: premium Team vs Team slideshow ===== */

.daily-team-showcase {
  width: 100%;
  max-width: 100%;
  margin: 0 0 22px;
  padding: 14px;
  border-radius: 26px;
  border: 1px solid rgba(255,255,255,0.08);
  background: linear-gradient(180deg, rgba(15,15,17,0.94), rgba(7,7,9,0.97));
  box-shadow: 0 22px 70px rgba(0,0,0,0.36);
  overflow: hidden;
}

.daily-team-shortcuts {
  display: flex;
  gap: 8px;
  overflow-x: auto;
  padding: 2px 2px 12px;
  scroll-snap-type: x proximity;
}

.daily-team-shortcuts::-webkit-scrollbar,
.daily-team-showcase-track::-webkit-scrollbar {
  height: 7px;
}

.daily-team-shortcuts::-webkit-scrollbar-thumb,
.daily-team-showcase-track::-webkit-scrollbar-thumb {
  background: rgba(255,255,255,0.14);
  border-radius: 999px;
}

.daily-team-shortcut {
  flex: 0 0 auto;
  scroll-snap-align: start;
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 9px 12px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,0.085);
  background: rgba(255,255,255,0.045);
  color: rgba(245,245,247,0.78);
  text-decoration: none;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.daily-team-shortcut b {
  color: rgba(245,245,247,0.34);
  font-size: 10px;
}

.daily-team-shortcut:hover {
  background: rgba(255,255,255,0.075);
  color: #f5f5f7;
}

.daily-team-showcase-track {
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: minmax(520px, 62vw);
  gap: 14px;
  overflow-x: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  padding-bottom: 8px;
}

.daily-team-slide {
  scroll-snap-align: center;
  min-height: 190px;
  padding: 16px;
  border-radius: 22px;
  border: 1px solid rgba(255,255,255,0.085);
  background:
    radial-gradient(circle at 50% 0%, rgba(255,255,255,0.075), transparent 36%),
    linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.018));
  box-shadow: none !important;
}

.daily-team-slide-top,
.daily-team-slide-footer {
  display: flex;
  justify-content: space-between;
  gap: 12px;
  color: rgba(245,245,247,0.48);
  font-size: 11px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  font-weight: 800;
}

.daily-team-slide-top strong {
  color: rgba(245,245,247,0.76);
}

.daily-team-versus {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
  align-items: center;
  gap: 18px;
  margin: 22px 0 20px;
}

.daily-team-side {
  display: grid;
  grid-template-columns: 52px minmax(0, 1fr);
  grid-template-areas:
    "logo name"
    "logo pitcher";
  align-items: center;
  column-gap: 13px;
  min-width: 0;
}

.daily-team-side-right {
  grid-template-columns: minmax(0, 1fr) 52px;
  grid-template-areas:
    "name logo"
    "pitcher logo";
  text-align: right;
}

.daily-team-logo {
  grid-area: logo;
  width: 52px;
  height: 52px;
  border-radius: 18px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(255,255,255,0.10);
  background: rgba(255,255,255,0.075);
  overflow: hidden;
  color: #f5f5f7;
  font-weight: 900;
}

.daily-team-logo img {
  width: 38px;
  height: 38px;
  object-fit: contain;
}

.daily-team-side h3 {
  grid-area: name;
  margin: 0;
  color: #f5f5f7;
  font-size: clamp(17px, 1.6vw, 24px);
  line-height: 1.05;
  letter-spacing: -0.045em;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.daily-team-side p {
  grid-area: pitcher;
  margin: 6px 0 0;
  color: rgba(245,245,247,0.54);
  font-size: 12px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.daily-team-vs-pill {
  width: 42px;
  height: 42px;
  border-radius: 999px;
  display: grid;
  place-items: center;
  border: 1px solid rgba(255,255,255,0.10);
  background: rgba(255,255,255,0.07);
  color: rgba(245,245,247,0.72);
  font-size: 11px;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.daily-team-slide-footer {
  padding-top: 12px;
  border-top: 1px solid rgba(255,255,255,0.07);
}

/* Make the big game/player blocks beneath feel less huge */
#root [data-page="daily-players"] article:not(.daily-team-slide):not(.daily-live-team-card) {
  border-radius: 18px !important;
}

#root [data-page="daily-players"] article:not(.daily-team-slide):not(.daily-live-team-card) img {
  width: 48px !important;
  height: 48px !important;
}

@media (max-width: 900px) {
  .daily-team-showcase-track {
    grid-auto-columns: minmax(310px, 90vw);
  }

  .daily-team-versus {
    grid-template-columns: 1fr;
    gap: 14px;
    text-align: left;
  }

  .daily-team-side,
  .daily-team-side-right {
    grid-template-columns: 48px minmax(0, 1fr);
    grid-template-areas:
      "logo name"
      "logo pitcher";
    text-align: left;
  }

  .daily-team-vs-pill {
    width: auto;
    height: auto;
    padding: 7px 10px;
    justify-self: start;
  }
}

