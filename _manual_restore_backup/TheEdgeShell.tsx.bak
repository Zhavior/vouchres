import { AnimatePresence, motion } from 'framer-motion';
import type { FormEvent } from 'react';
import { useEffect, useMemo, useState } from 'react';
import { ArrowRight, Bell, Bot, Check, CreditCard, Home, Layers3, Lock, LogIn, Palette, Radio, ShieldCheck, Sparkles, TrendingUp, Trophy, Users, X } from 'lucide-react';
