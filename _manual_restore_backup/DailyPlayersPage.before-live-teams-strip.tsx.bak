        <div className="flex items-center justify-between gap-4">
          <div>
            <div className="h-4 w-40 animate-pulse rounded-full bg-cyan-300/20" />
            <div className="mt-4 h-9 w-72 animate-pulse rounded-2xl bg-slate-800" />
